# URL of the GLPI release tarball (official GitHub releases recommended)
NEW_VERSION_URL="https://github.com/glpi-project/glpi/releases/download/11.0.6/glpi-11.0.6.tgz"

# Paths (adapt to your instance)
GLPI_DIR="/var/www/glpi"
BACKUP_DIR="/var/backups/glpi"
TMP_DIR="/tmp/glpi_update"

# Database
DB_NAME="glpi"
DB_USER="glpi"
# Recommended: DO NOT put DB_PASS here for GitHub.
# Use ~/.my.cnf for the user running the dump, or export DB_PASS locally.
# DB_PASS=""

# Apache / PHP user
APACHE_USER="www-data"
GLPI_CONSOLE_USER="www-data"

# Optional
# DUMP_BIN="mariadb-dump"   # or "mysqldump"
# ENABLE_MAINTENANCE="0"
# KEEP_TMP="0"